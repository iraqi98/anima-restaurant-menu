<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ANIMA CAFÉ & PIZZERIA</title>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Cairo:wght@400;600;700&family=Montserrat:wght@700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"></noscript>
    <script src="data_v2.js"></script>
    <!-- Rising Emojis Fixed -->
    <style>
.rising-emojis {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100vw;
  height: 120vh;
  pointer-events: none;
  z-index: -2;
  overflow: hidden;
}
.emoji-bubble {
  position: absolute;
  font-size: 26px;
  opacity: 0;
  animation: riseBottomToTop 9s cubic-bezier(0.25, 0.46, 0.45, 0.94) infinite;
  pointer-events: none;
  user-select: none;
  filter: drop-shadow(0 0 0 transparent);
  will-change: transform;
}
@keyframes riseBottomToTop {
  0% {
    bottom: -70px;
    opacity: 0;
    transform: translateX(0) rotate(0deg) scale(0.5);
  }
  10% {
    opacity: 0.45;
    transform: translateX(0) rotate(3deg) scale(0.9);
  }
  40%, 80% {
    opacity: 0.25;
  }
  95% {
    opacity: 0.1;
    transform: translateX(40px) rotate(-3deg) scale(1.2);
  }
  100% {
    bottom: 120vh;
    opacity: 0;
    transform: translateX(60px) rotate(0deg) scale(1.3);
  }
}
    </style>
    <!-- Original CSS intact -->
    <style>
/* With all original styles from your index.html - full page preserved */
* { box-sizing: border-box; margin: 0; padding: 0; }
@keyframes fadeIn { 0% { opacity: 0; transform: scale(0.95); } 100% { opacity: 1; transform: scale(1); } }
@keyframes floatLogo { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
/* ... (all other original CSS exactly as before - abbreviated for brevity) */
body { font-family: 'Roboto', 'Cairo', sans-serif; background: #01164B; color: #fff; line-height: 1.6; direction: ltr; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center; position: relative; }
/* Rest of CSS unchanged */
    </style>
</head>
<body>
    <!-- Rising Emojis -->
    <div class="rising-emojis" id="risingEmojis"></div>
    <!-- Original full page content unchanged -->
    <div class="wave-container" id="music-waves">
        <div class="wave wave3"></div>
        <div class="wave wave2"></div>
        <div class="wave"></div>
    </div>
    <header class="top-navbar">
        <div class="navbar-content">
            <div class="spacer"></div>
            <div class="nav-buttons">
                <button id="music-btn" class="menu-button" onclick="toggleMusic()" title="Play Ambience">
                    <i class="fas fa-music"></i>
                </button>
                <button id="lang-btn" class="menu-button" onclick="toggleLanguage()">AR</button>
            </div>
        </div>
    </header>
    <div id="parallax-wrapper">
        <img src="Anmialogo..png" alt="ANIMA Logo" class="logo">
        <a href="menu.html" class="menu-btn" id="main-menu-btn">View Menu</a>
    </div>
    <audio id="ambient-audio" loop>
        <source src="https://cdn.pixabay.com/download/audio/2022/05/27/audio_1808fbf07a.mp3?filename=lofi-study-112191.mp3" type="audio/mpeg">
    </audio>
    <footer class="social-footer">
        <a href="https://www.instagram.com/anima.iqq?igsh=bGExN2oycjc3aTl4" class="social-icon instagram-interactive" target="_blank" title="Instagram">
            <i class="fab fa-instagram"></i>
        </a>
        <a href="https://www.tiktok.com/@anima.iqq?_r=1&_t=ZS-95Yv81DVh0n" class="social-icon tiktok-original" target="_blank" title="TikTok">
            <img src="tiktok-icon.png" alt="TikTok" class="tiktok-img">
        </a>
    </footer>
    <script>
        // Original JS intact + Fixed Emojis
        let currentLang = localStorage.getItem('anima_lang') || 'en';
        // ... (all original language/music/parallax/sparkle code unchanged)
        // Fixed Emojis JS
        const cuteEmojis = ['☕','🍵','🥤','🍕','🍔','🌮','🍜','🍨','🍦','🍩','🥐','🍭','🍬','🥛','🧋'];
        function createRisingEmoji() {
          const bubble = document.createElement('div');
          bubble.className = 'emoji-bubble';
          bubble.textContent = cuteEmojis[Math.floor(Math.random() * cuteEmojis.length)];
          bubble.style.left = (Math.random() * 90 + 5) + '%';
          bubble.style.animationDuration = (8 + Math.random() * 2) + 's';
          document.getElementById('risingEmojis').appendChild(bubble);
          setTimeout(() => bubble.remove(), 11000);
        }
        // Start
        for(let i = 0; i < 8; i++) setTimeout(createRisingEmoji, i * 300);
        setInterval(createRisingEmoji, 700 + Math.random() * 400);
        console.log('🌟 إيموجي شفافة بدأت!');
        // Original JS continues...
    </script>
</body>
</html>
